# NOTE: Valores abaixo são placeholders válidos para subir o backend na primeira execução.
# Troque JWT_SECRET e WEBHOOK_SECRET em produção.
# Server Configuration
PORT=3000
NODE_ENV=development
# SECURITY: Bind to localhost by default. Use HOST=0.0.0.0 only when you need to expose the server to other machines (e.g., in Docker or when accessing from other devices on the network)
HOST=127.0.0.1

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_PATH=./data/whatshybrid.db
# DATABASE_URL=postgresql://user:password@localhost:5432/whatshybrid

# JWT Configuration
# ⚠️ CRITICAL: Generate a secure random secret! Use this command:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# ⚠️ REPLACE THIS VALUE! Run: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64CHAR_VALUE_RUN_COMMAND_ABOVE
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =========================================
# AI Providers - Add your API keys
# =========================================

# OpenAI (GPT-4o, GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (Claude 3.5 Sonnet, Claude 3)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google AI (Gemini Pro)
GOOGLE_API_KEY=your-google-ai-api-key

# Groq (Llama 3.3, Mixtral - Ultra fast!)
GROQ_API_KEY=gsk_your-groq-api-key

# Mistral AI
MISTRAL_API_KEY=your-mistral-api-key

# Venice AI
VENICE_API_KEY=your-venice-api-key

# Cohere (RAG optimized)
COHERE_API_KEY=your-cohere-api-key

# Ollama (Local models)
OLLAMA_BASE_URL=http://localhost:11434

# AI Settings
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o
AI_FALLBACK_PROVIDERS=anthropic,groq
AI_CACHE_TTL=3600
AI_MAX_TOKENS=4096

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
# ⚠️ In PRODUCTION, specify allowed domains separated by comma:
#
# Para a extensão Chrome funcionar, web.whatsapp.com PRECISA estar na lista —
# o content_script roda nesse domínio e faz fetch ao backend.
#
# Example dev:
#   CORS_ORIGIN=http://localhost:3000,https://web.whatsapp.com
#
# Example produção:
#   CORS_ORIGIN=https://app.whatshybrid.com.br,https://web.whatsapp.com,chrome-extension://YOUR_EXTENSION_ID
#
# NEVER use * in production!
CORS_ORIGIN=http://localhost:3000,https://web.whatsapp.com

# Logging
LOG_LEVEL=info

# Webhooks
# ⚠️ Generate: node -e "console.log('WHK_' + require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=REPLACE_WITH_GENERATED_WEBHOOK_SECRET
WEBHOOK_RETRY_COUNT=3

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WhatsHybrid <noreply@whatshybrid.com>

# Redis (Optional - for caching/sessions)
REDIS_URL=redis://localhost:6379

# Stripe (Optional - for billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===== v8.3.0 — MercadoPago (BR billing) =====
# Pegue em https://www.mercadopago.com.br/developers/panel/credentials
# Use credentials de "Test" no dev e "Production" em prod
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
# Se true, usa sandbox URL para checkout. Default: false (production)
MERCADOPAGO_USE_SANDBOX=false

# URL pública do seu backend (usado em redirects e webhook callbacks)
# Em prod: https://api.seudominio.com.br
PUBLIC_BASE_URL=http://localhost:3000

# ===== v8.3.0 — Billing Cron =====
# Schedule cron-style. Default: '0 3 * * *' (todo dia 03:00)
BILLING_CRON_SCHEDULE=0 3 * * *
# Set true para desabilitar o cron (útil em dev)
BILLING_CRON_DISABLED=false

# ===== v8.4.0 — Email transacional (SendGrid) =====
# Crie em https://sendgrid.com - precisa verificar o domínio
SENDGRID_API_KEY=
EMAIL_FROM=noreply@whatshybrid.com.br
EMAIL_FROM_NAME=WhatsHybrid Pro
# Se SENDGRID_API_KEY vazio, emails são apenas logados (modo dry-run)
