{
  "name": "whatshybrid-backend",
  "version": "9.5.8",
  "description": "WhatsHybrid Pro Backend API - SmartBot IA Edition",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/utils/migration-runner.js up",
    "seed": "echo \"⚠️  No seed scripts available — schema seeded via migrations and database-legacy\"",
    "test": "node tests/smoke/run-all.js",
    "test:watch": "jest --watch",
    "test:contracts": "jest --testPathPattern=contracts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:unit": "jest tests/unit",
    "test:all": "jest --runInBand --forceExit",
    "test:smoke": "node tests/smoke/run-all.js",
    "test:auth": "node tests/smoke/auth-flow.test.js",
    "test:tokens": "node tests/smoke/tokens-flow.test.js",
    "test:tenant": "node tests/smoke/tenant-isolation.test.js",
    "migrate:up": "node src/utils/migration-runner.js up",
    "migrate:status": "node src/utils/migration-runner.js status",
    "migrate:sqlite-to-postgres": "node scripts/migrate-sqlite-to-postgres.js",
    "migrate:sqlite-to-postgres:dry": "node scripts/migrate-sqlite-to-postgres.js --dry-run"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "socket.io": "^4.7.4",
    "tesseract.js": "^5.0.4",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "better-sqlite3": "^9.4.3",
    "redis": "^4.6.13",
    "rate-limit-redis": "^4.2.0",
    "bullmq": "^5.3.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.0.0",
    "@types/better-sqlite3": "^7.6.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "whatsapp",
    "automation",
    "crm",
    "api",
    "enterprise"
  ],
  "author": "WhatsHybrid Team",
  "license": "MIT"
}